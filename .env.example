# ── Supabase (required for Vercel deployment; optional for local dev) ──────────
#
# LOCAL DEV (default): SQLite is primary, no auth required. Leave all vars blank.
# With SUPABASE_URL set locally: writes go to SQLite AND Supabase (dual-write backup).
# On Vercel: set DB_PROVIDER=supabase — skips SQLite, uses Supabase as primary.
#
# Setup:
#   1. Create a free project at https://supabase.com
#   2. Run supabase-schema.sql in the Supabase SQL editor
#   3. Copy the values from Project Settings → API
#
# Server-side (secret — never expose to browser):
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Client-side (safe to expose — needed for login/auth in the browser):
# Must match the same project as SUPABASE_URL above.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Set to "supabase" on Vercel (no persistent filesystem for SQLite).
# Leave unset or set to "sqlite" for local development.
DB_PROVIDER=""

SUPABASE_SYNC_USER_ID= # local-dev only: user id used when backing up local SQLite to Supabase
